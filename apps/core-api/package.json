{
  "name": "@asashiki/core-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm && node scripts/fix-node-sqlite.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/cli/init-db.ts",
    "db:seed": "tsx src/cli/seed-db.ts",
    "smoke": "tsx src/cli/smoke-test.ts",
    "test": "tsx --test src/core-api.test.ts",
    "public:snapshot": "tsx src/cli/public-snapshot.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@asashiki/config": "workspace:*",
    "@asashiki/schemas": "workspace:*",
    "fastify": "^5.6.1",
    "zod": "^3.24.4"
  }
}
