NODE_ENV=production

CORE_API_BIND_HOST=0.0.0.0
CORE_API_HOST=0.0.0.0
CORE_API_PORT=4100
CORE_API_DB_PATH=/data/core-api.sqlite

# VPS-mounted private archive. The host path is mounted read-write into the
# core-api container as /archive (write access is used by write_diary_entry / update_diary_entry).
ASASHIKI_ARCHIVE_HOST_PATH=/opt/asashiki/Asashiki_Archive
ASASHIKI_ARCHIVE_ROOT=/archive
# Leave empty to auto-detect /archive/Obsidian_Asashiki/日记 or /archive/日记.
ASASHIKI_DIARY_DIR=

# Optional minimal text console at https://api.asashiki.com/console.
# If set, browser access uses Basic Auth username "admin" and this password.
ADMIN_PANEL_TOKEN=replace-with-a-long-random-password

# Optional remote MCP registry.
# Leave REMOTE_MCP_SERVERS_JSON empty to disable all upstream remote MCP connections.
REMOTE_MCP_SERVERS_JSON=[{"id":"supabase","name":"Supabase Remote MCP","url":"https://mcp.supabase.com/mcp?project_ref=zwpopwhdfmqtamkdcwkb&read_only=true","description":"read-only Supabase MCP for browsing tools and query tests","bearerTokenEnv":"SUPABASE_MCP_ACCESS_TOKEN"}]
SUPABASE_MCP_ACCESS_TOKEN=

# Optional dedicated time-log source.
# Leave these empty unless you explicitly want the time-log integration enabled.
SUPABASE_TIME_LOG_URL=
SUPABASE_TIME_LOG_BEARER_TOKEN=
SUPABASE_TIME_LOG_NAME=Supabase 时间日志

# Device agent tokens. JSON array of {token, deviceId, deviceName, platform}.
# Each device agent sends Authorization: Bearer <token> to POST /api/devices/report
# and POST /api/devices/health.
# Leave empty to disable device ingestion (endpoints return 401).
# Example: [{"token":"secret123","deviceId":"phone-1","deviceName":"Pixel","platform":"android"}]
DEVICE_TOKENS_JSON=

MCP_GATEWAY_BIND_HOST=0.0.0.0
MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=4200
MCP_CORE_API_BASE_URL=http://core-api:4100
