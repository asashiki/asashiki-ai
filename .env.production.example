NODE_ENV=production

CORE_API_BIND_HOST=0.0.0.0
CORE_API_HOST=0.0.0.0
CORE_API_PORT=4100
CORE_API_DB_PATH=/data/core-api.sqlite

# Optional remote MCP registry.
# Leave REMOTE_MCP_SERVERS_JSON empty to disable all upstream remote MCP connections.
REMOTE_MCP_SERVERS_JSON=[{"id":"supabase","name":"Supabase Remote MCP","url":"https://mcp.supabase.com/mcp?project_ref=zwpopwhdfmqtamkdcwkb&read_only=true","description":"read-only Supabase MCP for browsing tools and query tests","bearerTokenEnv":"SUPABASE_MCP_ACCESS_TOKEN"}]
SUPABASE_MCP_ACCESS_TOKEN=

# Optional dedicated time-log source.
# Leave these empty unless you explicitly want the time-log integration enabled.
SUPABASE_TIME_LOG_URL=
SUPABASE_TIME_LOG_BEARER_TOKEN=
SUPABASE_TIME_LOG_NAME=Supabase 时间日志

MCP_GATEWAY_BIND_HOST=0.0.0.0
MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=4200
MCP_CORE_API_BASE_URL=http://core-api:4100
